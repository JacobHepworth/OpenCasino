# Backup your current .gitignore first (just in case)
Copy-Item .gitignore .gitignore.old

# Create the new recommended .gitignore
@'
# ================================================
# Root .gitignore for Capacitor Project (OpenCasino)
# ================================================

# Dependencies
node_modules/

# Logs and temporary files
*.log
*.log.*
.DS_Store
Thumbs.db

# Environment / secret files (never commit these)
.env
.env.local
.env.*.local
.ps1

# Built APKs and App Bundles (generated files)
*.apk
*.aab
*.ap_

# Android Studio / IntelliJ IDE settings (machine-specific)
android/.idea/
*.iml

# Gradle / build caches (the android/ folder has its own .gitignore too)
android/.gradle/
android/build/
android/app/build/
android/captures/
android/local.properties

# Capacitor temporary / generated files
capacitor.config.*.ts

# Optional: If you ever add large media or other temp files
# www/assets/build/
'@ | Set-Content -Path .gitignore -Encoding UTF8